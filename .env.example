# Copy this file to .env and fill in only the values you need.

# Required for live Anthropic evaluation and draft generation.
ANTHROPIC_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
# ANTHROPIC_EVAL_MODEL is the primary (strong) model used for the escalation/
# second pass. ANTHROPIC_TRIAGE_MODEL is the cheaper model used for the first
# pass over every shortlisted contact; uncertain contacts are escalated to the
# primary model. Set ANTHROPIC_TRIAGE_MODEL equal to the eval model (or set
# EVIDENT_TIERED_ROUTING=0) to disable tiered routing.
ANTHROPIC_EVAL_MODEL=
ANTHROPIC_DRAFT_MODEL=
ANTHROPIC_TRIAGE_MODEL=
EVIDENT_TIERED_ROUTING=1

# Database settings.
DB_PATH=outreach_agent.db
DATABASE_URL=sqlite:///outreach_agent.db

# App runtime.
APP_ENV=development
APP_MODE=local
HOST=127.0.0.1
PORT=8080
CORS_ALLOW_ORIGINS=*

# Optional single-user privacy gate for cloud deployment.
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=

# Request validation and crawl pacing.
MAX_REQUEST_BODY_BYTES=200000
MAX_REQUESTS_PER_RUN=40
MAX_REQUESTS_PER_MINUTE=20
PER_DOMAIN_COOLDOWN_SECONDS=0.15

# Optional public-demo protections.
DEMO_API_KEY=
RUN_REQUEST_DAILY_LIMIT=0
RUN_REQUESTS_PER_MINUTE=0
MAX_DRAFTS_PER_RUN=5
MAX_EVALUATIONS_PER_RUN=8
